# Cbilling.TV Addon Configuration
# Copy this file to .env and fill in your real values
# DO NOT commit .env to git!

# Public key (access code) from your Cbilling account
CBILLING_PUBLIC_KEY=your_public_key_here

# API server URL
CBILLING_API_URL=http://your-api-server.com

# Stream server (optional, auto-detected from /auth/info)
CBILLING_STREAM_SERVER=stream.example.com
